# Multi-stage build for App API
# Pin base image to digest for reproducible builds
FROM python:3.13-slim@sha256:739e7213785e88c0f702dcdc12c0973afcbd606dbf021a589cab77d6b00b579d AS builder

# Install uv (pinned to specific version for reproducibility)
COPY --from=ghcr.io/astral-sh/uv:0.7.12 /uv /uvx /bin/

# Set working directory
WORKDIR /app

# Install system dependencies needed for any native builds
RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    && rm -rf /var/lib/apt/lists/*

# Copy dependency files first (layer caching — deps change less often than code)
COPY backend/pyproject.toml backend/README.md ./
COPY backend/uv.lock ./

# Install dependencies only (not the project itself) from the locked versions
# --frozen: use the lock file as-is, no network resolution, pure replay
# --extra agentcore: include the agentcore optional dependency group (strands, etc.)
# --no-install-project: install deps only, skip the project package
# --no-dev: exclude development dependencies
# --no-editable: non-editable install for production
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --extra agentcore --no-install-project --no-dev --no-editable

# Copy source code and install the project itself
COPY backend/src ./src
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --extra agentcore --no-dev --no-editable

# Production stage
FROM python:3.13-slim@sha256:739e7213785e88c0f702dcdc12c0973afcbd606dbf021a589cab77d6b00b579d

WORKDIR /app

# Install runtime dependencies (curl required for HEALTHCHECK)
RUN apt-get update && apt-get install -y \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy the virtual environment from builder
COPY --from=builder /app/.venv /app/.venv

# Copy application code
COPY backend/src /app/src

# Create necessary directories
RUN mkdir -p /app/output /app/uploads /app/generated_images

# Create non-root user for security
RUN useradd -m -u 1000 -s /bin/bash appuser && \
    chown -R appuser:appuser /app

# Switch to non-root user
USER appuser

# Version injection (defaults to "unknown" if not provided via --build-arg)
ARG APP_VERSION=unknown
ENV APP_VERSION=${APP_VERSION}

# Set environment variables
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app/src
ENV PATH="/app/.venv/bin:$PATH"

# Expose port
EXPOSE 8000

# Health check
HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

# Run the application
CMD ["uvicorn", "apis.app_api.main:app", "--host", "0.0.0.0", "--port", "8000"]
